{
    "name": "nexo/plugin-sdk",
    "description": "PHP SDK for nexo subprocess plugins",
    "type": "library",
    "keywords": ["nexo", "plugin", "json-rpc", "agent", "subprocess"],
    "homepage": "https://github.com/lordmacu/nexo-plugin-sdks/tree/main/php",
    "license": ["MIT", "Apache-2.0"],
    "authors": [
        {
            "name": "Cristian Garcia",
            "email": "informacion@cristiangarcia.co"
        }
    ],
    "support": {
        "issues": "https://github.com/lordmacu/nexo-plugin-sdks/issues",
        "source": "https://github.com/lordmacu/nexo-plugin-sdk-php"
    },
    "require": {
        "php": "^8.1",
        "yosymfony/toml": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Nexo\\Plugin\\Sdk\\": "src/"
        }
    },
    "scripts": {
        "test": "php tests/run-all.php"
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist"
    },
    "minimum-stability": "stable"
}
